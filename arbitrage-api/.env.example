EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_ENV=sandbox
EBAY_MARKETPLACE=EBAY_GB
TARGET_MARGIN_PCT=0.20
# Was 0.14 here but the code hardcoded 0.1325 and ignored this var entirely
# (see the old EBAY_FEE_PCT trap note below). Now wired via os.getenv, so
# fixed to match the code's real-world default — set this and it takes effect.
EBAY_FEE_PCT=0.1325

# Full-cost Margin Calculator (§4A.2, arbitrage-api/services/margin_engine.py
# evaluate_margin()). Loaded via os.getenv with these exact values as
# fallback defaults, so the calculator works even if this block is unset.
# Returns/FX numbers below are PLACEHOLDERS — replace with measured values
# once the inbound loop has real data.
PROMOTED_LISTINGS_PCT=0.02        # 0 if not running Promoted Listings
PAYMENT_FX_PCT=0.02               # Wise/Payoneer KE settlement — measure & replace
EXPECTED_RETURN_RATE=0.05         # PLACEHOLDER — replace with your measured return rate
RETURN_SHIPPING_LOSS=8.00         # $ you eat per return (return shipping) — estimate, refine later
MIN_NET_MARGIN_PCT=0.20           # risk-management floor, not a profit guarantee — tune from measured P&L
MIN_NET_PROFIT_ABS=5.00           # risk-management floor (USD), not a profit guarantee — tune from measured P&L

# Comma-separated API keys accepted by the X-API-Key header.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEYS=
# fulfillment_bot.py's key for calling PATCH /orders/{id}/status back to this
# API. Must be one of the values listed in API_KEYS above.
BOT_API_KEY=
# Set to "true" to expose /docs, /redoc, /openapi.json (leave unset/false in production)
ENABLE_DOCS=false

# Human-in-the-loop fulfillment gate (see fulfillment_gate.py).
# Both the API service and the fulfillment_bot.py service must set these
# to the SAME values (ideally an absolute FULFILLMENT_QUEUE path) so they
# agree on one queue file regardless of each process's working directory.
ABSOLUTE_MAX_ORDER=150
DAILY_SPEND_CAP=500
FULFILLMENT_QUEUE=fulfillment_queue.json

# Per-deploy paths — override these so a repointed clone/VPS move doesn't
# silently keep reading/writing the old location. fulfillment_bot.py reads
# SESSION_FILE and DEBUG_DIR (falls back to /root/arbitrage-api/... if unset).
# DB_PATH is documented here for the same reason but is NOT yet wired into
# database.py (which still resolves arbitrage.db relative to cwd) — treat it
# as inert until that's connected, same trap as the old EBAY_FEE_PCT.
SESSION_FILE=/root/arbitrage-api/amazon_session.json
DEBUG_DIR=/root/arbitrage-api
DB_PATH=/root/arbitrage-api/arbitrage.db

# AI Product Scorer (§4A.3, arbitrage-api/services/model_providers.py).
# Provider-agnostic — pick one via SCORER_PROVIDER, set SCORER_MODEL to that
# provider's model id, and fill in only the matching API key below.
# Kimi's base URL/model id were confirmed against OpenClaw's own (separately
# running) Kimi Coding config — this app does NOT call through OpenClaw,
# it talks to Kimi's endpoint directly.
SCORER_PROVIDER=kimi
SCORER_MODEL=kimi-for-coding
KIMI_API_KEY=
KIMI_BASE_URL=https://api.kimi.com/coding
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
# Cost guard for POST /scoring/run — refuses to score more than this many
# candidates in one call (real money: every candidate scored is a paid API call).
SCORING_BATCH_MAX=25

# Telegram approver (telegram_approver.py) — talks to fulfillment_gate.py
# directly, does not use API_KEYS. Service refuses to start if
# TELEGRAM_ALLOWED_IDS is empty.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALLOWED_IDS=
APPROVAL_BUFFER_PCT=0.10
POLL_INTERVAL=30
