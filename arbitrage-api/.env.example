EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_ENV=sandbox
EBAY_MARKETPLACE=EBAY_GB
TARGET_MARGIN_PCT=0.20
EBAY_FEE_PCT=0.14

# Comma-separated API keys accepted by the X-API-Key header.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEYS=

# Human-in-the-loop fulfillment gate (see fulfillment_gate.py).
# Both the API service and the fulfillment_bot.py service must set these
# to the SAME values (ideally an absolute FULFILLMENT_QUEUE path) so they
# agree on one queue file regardless of each process's working directory.
ABSOLUTE_MAX_ORDER=150
DAILY_SPEND_CAP=500
FULFILLMENT_QUEUE=fulfillment_queue.json
